<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Request a Repair</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #F7F7F5;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
    }

    .card {
      background: #ffffff;
      border-radius: 16px;
      padding: 40px 36px;
      max-width: 460px;
      width: 100%;
      box-shadow: 0 2px 24px rgba(0,0,0,0.07);
    }

    .badge {
      display: inline-block;
      background: #FFF3E0;
      color: #E65100;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 20px;
      margin-bottom: 16px;
    }

    h1 {
      font-size: 24px;
      font-weight: 700;
      color: #1A1A1A;
      line-height: 1.3;
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 14px;
      color: #777;
      margin-bottom: 32px;
      line-height: 1.5;
    }

    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #333;
      margin-bottom: 6px;
    }

    input, select {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #E0E0E0;
      border-radius: 10px;
      font-size: 15px;
      color: #1A1A1A;
      background: #FAFAFA;
      outline: none;
      transition: border-color 0.2s;
      margin-bottom: 20px;
      appearance: none;
      -webkit-appearance: none;
    }

    input:focus, select:focus {
      border-color: #E65100;
      background: #fff;
    }

    .select-wrap {
      position: relative;
    }

    .select-wrap::after {
      content: '▾';
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-70%);
      color: #999;
      pointer-events: none;
      font-size: 16px;
    }

    .select-wrap select {
      padding-right: 36px;
    }

    button[type="submit"] {
      width: 100%;
      padding: 14px;
      background: #E65100;
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      margin-top: 4px;
    }

    button[type="submit"]:hover {
      background: #BF360C;
    }

    button[type="submit"]:active {
      transform: scale(0.98);
    }

    .footer-note {
      text-align: center;
      font-size: 12px;
      color: #AAA;
      margin-top: 20px;
    }

    /* Success screen */
    .success {
      display: none;
      text-align: center;
      padding: 20px 0;
    }

    .success .tick {
      font-size: 52px;
      margin-bottom: 16px;
    }

    .success h2 {
      font-size: 22px;
      font-weight: 700;
      color: #1A1A1A;
      margin-bottom: 10px;
    }

    .success p {
      font-size: 15px;
      color: #666;
      line-height: 1.6;
    }

    .success .whatsapp-note {
      margin-top: 20px;
      background: #E8F5E9;
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 14px;
      color: #2E7D32;
      font-weight: 600;
    }

    .loading {
      display: none;
      text-align: center;
      padding: 10px 0;
      font-size: 14px;
      color: #999;
    }
  </style>
</head>
<body>
  <div class="card">

    <!-- Form View -->
    <div id="form-view">
      <div class="badge">Quick Request</div>
      <h1>Book a Repair</h1>
      <p class="subtitle">Fill in your details and we'll reach out on WhatsApp to sort everything out.</p>

      <form id="repair-form">

        <label for="name">Full Name</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="John Smith"
          required
        />

        <label for="phone">WhatsApp Number</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="+61 400 000 000"
          required
        />

        <label for="repair_type">Type of Repair</label>
        <div class="select-wrap">
          <select id="repair_type" name="repair_type" required>
            <option value="" disabled selected>Select repair type</option>
            <option value="Plumbing">Plumbing</option>
            <option value="Electrical">Electrical</option>
            <option value="Roofing">Roofing</option>
            <option value="Air Conditioning">Air Conditioning</option>
            <option value="Carpentry">Carpentry</option>
            <option value="Painting">Painting</option>
            <option value="Tiling">Tiling</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="loading" id="loading">Sending your request...</div>

        <button type="submit" id="submit-btn">Get Help on WhatsApp →</button>
      </form>

      <p class="footer-note">We'll message you within minutes. Available 10am – 4pm.</p>
    </div>

    <!-- Success View -->
    <div class="success" id="success-view">
      <div class="tick">✅</div>
      <h2>Request Received!</h2>
      <p>Thanks for reaching out. Our team will be in touch with you shortly.</p>
      <div class="whatsapp-note">
        📲 Check your WhatsApp — we'll message you there to get the details sorted.
      </div>
    </div>

  </div>

  <script>
    const form = document.getElementById('repair-form');
    const formView = document.getElementById('form-view');
    const successView = document.getElementById('success-view');
    const loading = document.getElementById('loading');
    const submitBtn = document.getElementById('submit-btn');

    const WEBHOOK_URL = 'https://hook.eu1.make.com/ful5at6p9bkfcselhqvy2ou08w23a6xm';

    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const name = document.getElementById('name').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const repair_type = document.getElementById('repair_type').value;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      loading.style.display = 'block';

      const payload = {
        name: name,
        phone: phone,
        repair_type: repair_type,
        submitted_at: new Date().toISOString(),
        source: 'repair-form'
      };

      try {
        await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
      } catch (err) {
        console.error('Webhook error:', err);
      }

      // Always show success regardless
      formView.style.display = 'none';
      successView.style.display = 'block';
    });
  </script>
</body>
</html>
